# Clone source from upstream.
# Keep v0.20.0 if you want to stay aligned with the Railway wrapper.
IRONCLAW_REPO=https://github.com/nearai/ironclaw.git
IRONCLAW_REF=v0.20.0

# PostgreSQL
POSTGRES_DB=ironclaw
POSTGRES_USER=ironclaw
POSTGRES_PASSWORD=change-me

# Keep this in sync with the values above.
# Use a URL-safe password unless you also URL-encode it here.
DATABASE_URL=postgresql://ironclaw:change-me@db:5432/ironclaw?sslmode=disable

# LLM provider
LLM_BACKEND=openai
OPENAI_API_KEY=sk-your-openai-key

# Secrets
SECRETS_MASTER_KEY=replace-with-a-long-random-secret
GATEWAY_AUTH_TOKEN=replace-with-a-long-random-login-token
HTTP_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret

# Hosted/container defaults
SANDBOX_ENABLED=true
